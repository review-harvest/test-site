---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/global/Nav.astro';
import Footer from '../components/global/Footer.astro';
import CallToAction from '../components/global/CallToAction.astro';
import Hero from '../components/home/Hero.astro';
import Services from '../components/home/Services.astro';
import Process from '../components/home/Process.astro';
import WhyUs from '../components/home/WhyUs.astro';
import Testimonials from '../components/home/Testimonials.astro';
import { business } from '../data/business';
---

<Layout
  title={`${business.name} | Dog Waste Removal in Prosper, Frisco, McKinney, TX`}
  description="Professional dog waste removal in Prosper, Frisco, McKinney & DFW. Weekly, bi-weekly & one-time cleanup. No contracts. Starts at $52/mo."
>

  <Nav
    businessName={business.name}
    phone={business.phone}
    links={business.nav}
    ctaHref={business.ctaHref}
  />

  <Hero
    eyebrow="Serving Prosper, Frisco, McKinney & Celina"
    headline="Poop Scooping Service in Prosper, TX"
    subtext="Professional, no-contract poop scooping for DFW homeowners. We remove all pet waste, sanitize our tools, and notify you when done. Starts at $52/month."
    primaryCta={{ label: 'Get an Instant Quote', href: business.ctaHref }}
    secondaryCta={{ label: 'See Our Services', href: '/services' }}
    stats={business.stats}
  />


  <Services
    eyebrow="What We Do"
    heading="Dog Waste Removal Services in Prosper, Frisco & DFW"
    subtext="Residential and commercial poop scooping on your schedule: weekly, bi-weekly, monthly, or one-time."
    services={business.services.map(s => ({
      name: s.name,
      description: s.description,
      href: `/services/${s.slug}`,
    }))}
  />

  <Process
    eyebrow="How It Works"
    heading="Clean yard in four easy steps."
    subtext="Getting started takes just a few minutes. Here's exactly what happens after you sign up."
    steps={[
      {
        number: '01',
        title: 'Get an Instant Quote',
        description: 'Use our online portal to get a quote in minutes. Pick your plan and schedule. No phone call required.',
      },
      {
        number: '02',
        title: 'We Come to You',
        description: "Our crew arrives on your scheduled day. You don't even need to be home, just leave the gate accessible.",
      },
      {
        number: '03',
        title: 'Yard Cleaned & Sanitized',
        description: 'We remove all waste and use an organic kennel-grade disinfectant on our tools to keep your pets safe.',
      },
      {
        number: '04',
        title: "You're Good to Go",
        description: "Get notified when we're done. Enjoy your clean yard, and cancel or adjust your plan anytime.",
      },
    ]}
  />

  <WhyUs ctaHref={business.ctaHref} />

  <Testimonials
    eyebrow="Customer Reviews"
    heading="DFW Dog Owners Love a Clean Yard"
    testimonials={business.testimonials.slice(0, 3)}
  />

  <CallToAction
    eyebrow="Get Started Today"
    heading="Start Your Poop Scooping Service in Prosper, Frisco & DFW"
    subtext="Get an instant quote online or give us a call. No contracts, no commitments, just a cleaner yard starting this week."
    phone={business.phone}
    ctaLabel="Get an Instant Quote"
    ctaHref={business.ctaHref}
  />

  <Footer
    businessName={business.name}
    tagline={business.tagline}
    phone={business.phone}
    email={business.email}
    address={business.address.full}
    links={business.nav}
    serviceAreas={business.serviceAreas}
    social={business.social}
  />

</Layout>
