---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/global/Nav.astro';
import Footer from '../components/global/Footer.astro';
import CallToAction from '../components/global/CallToAction.astro';
import Story from '../components/about/Story.astro';
import Values from '../components/about/Values.astro';
import TeamGrid from '../components/about/TeamGrid.astro';
import Credentials from '../components/about/Credentials.astro';
import { business } from '../data/business';
---

<Layout
  title={`About Us | ${business.name}`}
  description={`Learn about ${business.name} — Austin's trusted plumbers since ${business.founded}. Meet our team, understand our values, and see our credentials.`}
>

  <Nav
    businessName={business.name}
    phone={business.phone}
    links={business.nav}
    ctaHref={business.ctaHref}
  />

  <Story
    eyebrow="Our Story"
    heading="Built on honesty. Proven by results."
    body1="Marcus Rivera started Apex Plumbing & Drain in 2009 after nearly a decade working for larger plumbing companies in the Austin area. The work was good, but the business practices weren't — inflated quotes, unnecessary upsells, technicians rushing through jobs to hit daily ticket counts."
    body2="He started Apex because he believed there was a better way. Give honest quotes. Do the work right the first time. Stand behind it completely. Over 15 years and 8,400+ jobs later, that approach has built a company that Austin homeowners actually call their friends about."
    founded={business.founded}
    accentStat={{ value: '8,400+', label: 'jobs completed since 2009' }}
  />

  <Values
    eyebrow="What We Stand For"
    heading="The principles behind every job we take."
    subtext="These aren't words on a website. They're the standards we hold ourselves to — and that our customers can hold us to."
    values={business.values}
  />

  <TeamGrid
    eyebrow="Meet the Team"
    heading="The people behind every job."
    subtext="Our team is small by design. You'll work with experienced professionals on every visit — not whoever happens to be available."
    members={business.team}
  />

  <Credentials
    eyebrow="Licenses & Certifications"
    heading="You can verify everything we claim."
    credentials={business.credentials}
  />

  <CallToAction
    eyebrow="Work With Us"
    heading="Ready to experience the difference?"
    subtext="Call us for a free, no-obligation quote. We answer every call personally."
    phone={business.phone}
    ctaLabel="Send Us a Message"
    ctaHref="/contact"
  />

  <Footer
    businessName={business.name}
    tagline={business.tagline}
    phone={business.phone}
    email={business.email}
    address={business.address.full}
    links={business.nav}
    serviceAreas={business.serviceAreas}
  />

</Layout>
