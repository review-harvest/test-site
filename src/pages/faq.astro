---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/global/Nav.astro';
import Footer from '../components/global/Footer.astro';
import CallToAction from '../components/global/CallToAction.astro';
import FAQList from '../components/faq/FAQList.astro';
import { business } from '../data/business';

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": business.faqs.flatMap(cat => cat.questions.map(q => ({
    "@type": "Question",
    "name": q.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": q.answer.replace(/<[^>]*>/g, '')
    }
  })))
});
---

<Layout
  title={`FAQ | ${business.name} | DFW Poop Scooping`}
  description="FAQ: Doodie Crew dog waste removal — pricing, scheduling & satisfaction guarantee. Serving Prosper, Frisco, McKinney & DFW. No contracts."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={faqSchema} />
  </Fragment>

  <Nav
    businessName={business.name}
    phone={business.phone}
    ctaHref={business.ctaHref}
  />

  <FAQList
    eyebrow="Common Questions"
    heading="Everything you need to know."
    subtext={`Can't find your answer here? Call us at <a href="tel:+1${business.phone.replace(/\D/g,'')}" class="text-brand font-semibold hover:underline">${business.phone}</a>. We're happy to help.`}
    phone={business.phone}
    categories={business.faqs}
    titleLevel="h1"
  />

  <CallToAction
    eyebrow="Ready to Start?"
    heading="Questions answered. Let's get your yard clean."
    subtext="Get an instant quote online in minutes or give us a call. No contracts, no commitments."
    phone={business.phone}
    ctaLabel="Get an Instant Quote"
    ctaHref={business.ctaHref}
  />

  <Footer
    businessName={business.name}
    tagline={business.tagline}
    phone={business.phone}
    email={business.email}
    address={business.address.full}
    links={business.nav}
    serviceAreas={business.serviceAreas}
    social={business.social}
  />

</Layout>
