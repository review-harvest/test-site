---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/global/Nav.astro';
import Footer from '../components/global/Footer.astro';
import ContactForm from '../components/contact/ContactForm.astro';
import ContactInfo from '../components/contact/ContactInfo.astro';
import { business } from '../data/business';
---

<Layout
  title={`Contact Us | ${business.name} | Austin, TX`}
  description={`Contact ${business.name} in Austin, TX. Call ${business.phone} or submit a request online. We respond within 1 business hour.`}
>

  <Nav
    businessName={business.name}
    phone={business.phone}
    links={business.nav}
    ctaHref={business.ctaHref}
  />

  <!-- Contact split layout -->
  <section class="bg-bg py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

        <!-- Form — wider column -->
        <div class="lg:col-span-7">
          <ContactForm
            heading="Request a Free Quote"
            subtext="Fill out the form and we'll call to confirm your appointment — usually within the hour. Same-day service available for most requests."
            services={business.services.map(s => s.name).concat(['Other / Not Sure'])}
          />
        </div>

        <!-- Info — narrower column -->
        <div class="lg:col-span-5">
          <!-- Divider label -->
          <div class="flex items-center gap-4 mb-8 lg:hidden">
            <div class="flex-1 h-px bg-border"></div>
            <span class="font-body text-sm text-text-soft">or reach us directly</span>
            <div class="flex-1 h-px bg-border"></div>
          </div>

          <ContactInfo
            phone={business.phone}
            email={business.email}
            address={business.address.full}
            hours={business.hours}
          />
        </div>

      </div>
    </div>
  </section>

  <!-- Reassurance strip -->
  <div class="bg-brand-tint border-t border-b border-brand/15 py-8">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center sm:text-left">
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-3">
          <svg class="w-5 h-5 text-brand shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <p class="font-body font-semibold text-sm text-text">We respond within 1 hour</p>
            <p class="font-body text-sm text-text-soft">During business hours. Emergencies answered immediately.</p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-3">
          <svg class="w-5 h-5 text-brand shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
          <div>
            <p class="font-body font-semibold text-sm text-text">Written quote before work starts</p>
            <p class="font-body text-sm text-text-soft">No surprises. You approve everything upfront.</p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-3">
          <svg class="w-5 h-5 text-brand shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          <div>
            <p class="font-body font-semibold text-sm text-text">Same-day service available</p>
            <p class="font-body text-sm text-text-soft">Most non-emergency jobs scheduled same day.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer
    businessName={business.name}
    tagline={business.tagline}
    phone={business.phone}
    email={business.email}
    address={business.address.full}
    links={business.nav}
    serviceAreas={business.serviceAreas}
  />

</Layout>
