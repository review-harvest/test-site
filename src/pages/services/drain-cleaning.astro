---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/global/Nav.astro';
import Footer from '../../components/global/Footer.astro';
import CallToAction from '../../components/global/CallToAction.astro';
import ServiceDetail from '../../components/services/ServiceDetail.astro';
import RelatedServices from '../../components/services/RelatedServices.astro';
import Process from '../../components/home/Process.astro';
import Testimonials from '../../components/home/Testimonials.astro';
import FAQList from '../../components/faq/FAQList.astro';
import { business } from '../../data/business';

const service = business.services.find(s => s.slug === 'drain-cleaning')!;

const relatedServices = business.services
  .filter(s => s.slug !== 'drain-cleaning')
  .slice(0, 3)
  .map(s => ({ name: s.name, description: s.description, href: `/services/${s.slug}` }));

const relatedTestimonials = business.testimonials
  .filter(t => t.service === 'Drain Cleaning')
  .concat(business.testimonials.filter(t => t.service !== 'Drain Cleaning').slice(0, 2))
  .slice(0, 3);

const faqs = [
  {
    category: 'Drain Cleaning Questions',
    questions: [
      {
        question: 'How do I know if I need drain cleaning vs. a bigger repair?',
        answer: "A simple clog usually causes one slow drain. If multiple drains are slow or you hear gurgling sounds when you flush, it could indicate a main line issue. We'll diagnose the problem and tell you exactly what you need before any work begins.",
      },
      {
        question: 'How long does drain cleaning take?',
        answer: 'Most drain cleaning jobs take 30–90 minutes. Main sewer line clearing with camera inspection can take 2–3 hours. We give you a time estimate when we arrive.',
      },
      {
        question: 'Do you use chemicals or mechanical methods?',
        answer: 'We use professional-grade mechanical tools (snake machines, hydro-jetting) rather than chemical drain cleaners. Chemical cleaners damage pipes over time and rarely fix the root cause.',
      },
      {
        question: 'How much does drain cleaning cost?',
        answer: 'Basic drain cleaning typically runs $125–$275 depending on the location and severity of the clog. Camera inspection is an additional $150. We provide a written quote before starting.',
      },
      {
        question: 'Will the clog come back?',
        answer: "Depends on the cause. If it's grease buildup or debris, the fix is lasting with proper maintenance habits. If it's tree roots or a collapsed section, we'll let you know and explain your longer-term options.",
      },
    ],
  },
];
---

<Layout
  title={`Drain Cleaning & Unclogging | ${business.name} | Austin, TX`}
  description="Professional drain cleaning and unclogging in Austin, TX. Camera inspection included. Kitchen, bathroom, and main sewer line service. Call (512) 555-0142."
>

  <Nav
    businessName={business.name}
    phone={business.phone}
    links={business.nav}
    ctaHref={business.ctaHref}
  />

  <ServiceDetail
    name={service.name}
    tagline="Camera inspection included on every job"
    description="Slow drains are more than an annoyance — they're often the first sign of a larger problem. Our licensed plumbers use professional snake machines and hydro-jetting equipment to clear clogs completely, and we include a camera inspection to find the root cause rather than just treating symptoms. Kitchen grease buildup, hair clogs, tree root intrusion — we've seen it all and fixed it all."
    benefits={[
      'Camera inspection included at no extra charge',
      'Kitchen, bathroom, and main sewer line clearing',
      'Hydro-jetting for stubborn grease and mineral buildup',
      'Tree root removal and treatment',
      'Complete drain-to-stack inspection',
      'Written report with photos of findings',
    ]}
    guarantee="All drain cleaning work is backed by our 1-year labor warranty."
  />

  <Process
    eyebrow="Our Process"
    heading="How drain cleaning works."
    subtext="We don't guess. We diagnose, explain, and fix — with your approval at every step."
    steps={[
      { number: '01', title: 'Visual Inspection', description: 'We inspect the drain, check water flow from multiple fixtures, and listen to how your system behaves.' },
      { number: '02', title: 'Camera Diagnosis', description: 'We run a camera into the line to locate the exact blockage and identify the cause — grease, roots, collapsed pipe, or debris.' },
      { number: '03', title: 'Written Quote', description: 'We explain what we found, what it will take to fix it, and give you a written quote before touching anything.' },
      { number: '04', title: 'Clear & Verify', description: "We clear the blockage using the right method for the cause, then verify flow is fully restored before we leave." },
    ]}
  />

  <Testimonials
    eyebrow="From Our Customers"
    heading="What Austin homeowners say about our drain service."
    testimonials={relatedTestimonials}
  />

  <FAQList
    eyebrow="Common Questions"
    heading="Drain cleaning — answered."
    subtext="Still have questions? Call us at (512) 555-0142."
    categories={faqs}
  />

  <RelatedServices
    heading="Other services you might need"
    services={relatedServices}
  />

  <CallToAction
    eyebrow="Book Drain Cleaning"
    heading="Slow drain? Don't wait."
    subtext="Clogs get worse over time. Call us today for same-day drain cleaning in Austin."
    phone={business.phone}
    ctaLabel="Request Online"
    ctaHref="/contact"
  />

  <Footer
    businessName={business.name}
    tagline={business.tagline}
    phone={business.phone}
    email={business.email}
    address={business.address.full}
    links={business.nav}
    serviceAreas={business.serviceAreas}
  />

</Layout>
