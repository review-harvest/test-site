---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/global/Nav.astro';
import Footer from '../../components/global/Footer.astro';
import CallToAction from '../../components/global/CallToAction.astro';
import ServiceDetail from '../../components/services/ServiceDetail.astro';
import RelatedServices from '../../components/services/RelatedServices.astro';
import Process from '../../components/home/Process.astro';
import Testimonials from '../../components/home/Testimonials.astro';
import FAQList from '../../components/faq/FAQList.astro';
import { business } from '../../data/business';

const service = business.services.find(s => s.slug === 'emergency-plumbing')!;

const relatedServices = business.services
  .filter(s => s.slug !== 'emergency-plumbing')
  .slice(0, 3)
  .map(s => ({ name: s.name, description: s.description, href: `/services/${s.slug}` }));

const relatedTestimonials = business.testimonials
  .filter(t => t.service === 'Emergency Plumbing')
  .concat(business.testimonials.filter(t => t.service !== 'Emergency Plumbing').slice(0, 1))
  .slice(0, 3);

const faqs = [
  {
    category: 'Emergency Plumbing Questions',
    questions: [
      {
        question: 'What qualifies as a plumbing emergency?',
        answer: 'Burst pipes, active flooding, sewage backups, gas line issues, complete loss of water supply, or any situation where water damage is occurring or imminent. When in doubt, call us — we can help you assess over the phone.',
      },
      {
        question: 'How fast can you get to me?',
        answer: 'Our target for emergency calls is 2 hours or less, anywhere in our service area. In Austin proper, we often arrive faster. We tell you our honest ETA when you call.',
      },
      {
        question: 'Do you charge extra for emergency service?',
        answer: 'No. We believe emergency pricing is predatory. You pay the same rate whether it is 2pm on a Tuesday or 2am on a Saturday. The only difference is the job itself.',
      },
      {
        question: 'What should I do while waiting for you to arrive?',
        answer: 'Locate and shut off the main water supply valve (usually near the water meter or where the main line enters the house). Our dispatcher can walk you through it over the phone if you need help.',
      },
      {
        question: 'Can I prevent plumbing emergencies?',
        answer: 'Many emergencies are preventable with regular maintenance — annual inspections catch aging pipes, corroded fittings, and slow leaks before they become failures. Ask us about our maintenance program.',
      },
    ],
  },
];
---

<Layout
  title={`24/7 Emergency Plumbing | ${business.name} | Austin, TX`}
  description="24/7 emergency plumbing in Austin, TX. Burst pipes, flooding, sewage backups — on-site within 2 hours. No extra emergency charge. Call (512) 555-0142."
>

  <Nav
    businessName={business.name}
    phone={business.phone}
    links={business.nav}
    ctaHref={business.ctaHref}
  />

  <ServiceDetail
    name={service.name}
    tagline="24/7 · On-site within 2 hours · No extra fees"
    description="Plumbing emergencies don't wait for business hours, and neither do we. We staff emergency calls around the clock — every day of the year including holidays — and we charge the same rate at 3am as we do at 3pm. When you call, a real person answers, and a licensed plumber is on the way. Our goal is to stop the damage and fix the problem in one visit."
    benefits={[
      '24/7 availability — 365 days a year',
      'On-site within 2 hours, usually faster',
      'No extra charge for nights, weekends, or holidays',
      'Burst pipe repair and water damage mitigation',
      'Sewage backup clearing and sanitation',
      'Full repair completed same visit when possible',
    ]}
    guarantee="Emergency repairs are covered by the same 1-year labor warranty as all of our work."
  />

  <Process
    eyebrow="What Happens When You Call"
    heading="Fast, coordinated response."
    subtext="Every minute matters in an emergency. Here's how we handle it."
    steps={[
      { number: '01', title: 'Call — We Answer', description: 'A real person picks up. No voicemail, no callback queue. We triage your situation immediately and dispatch a plumber.' },
      { number: '02', title: 'Mitigate First', description: 'We walk you through shutting off water if needed, so damage stops before we arrive.' },
      { number: '03', title: 'On-Site in 2 Hours', description: 'Our technician arrives with the tools and parts needed for the most common emergency repairs.' },
      { number: '04', title: 'Fix & Verify', description: 'We repair the issue, test the system, and document everything — including photos for any insurance claims you may need to file.' },
    ]}
  />

  <Testimonials
    eyebrow="Emergency Calls We've Answered"
    heading="Real emergencies, real results."
    testimonials={relatedTestimonials}
  />

  <FAQList
    eyebrow="Emergency Plumbing FAQ"
    heading="What to know before you call."
    subtext="For active emergencies, don't read this — call us now at (512) 555-0142."
    categories={faqs}
  />

  <RelatedServices
    heading="Follow-up services often needed after emergencies"
    services={relatedServices}
  />

  <CallToAction
    eyebrow="Plumbing Emergency?"
    heading="Call now. We answer 24/7."
    subtext="Every minute counts when water is active. Don't wait — call us now."
    phone={business.phone}
    ctaLabel="Or Submit a Request"
    ctaHref="/contact"
  />

  <Footer
    businessName={business.name}
    tagline={business.tagline}
    phone={business.phone}
    email={business.email}
    address={business.address.full}
    links={business.nav}
    serviceAreas={business.serviceAreas}
  />

</Layout>
