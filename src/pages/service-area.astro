---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/global/Nav.astro';
import Footer from '../components/global/Footer.astro';
import CallToAction from '../components/global/CallToAction.astro';
import CoverageDetails from '../components/service-area/CoverageDetails.astro';
import CityGrid from '../components/service-area/CityGrid.astro';
import { business } from '../data/business';

const cities = [
  { name: 'Prosper', county: 'Collin County', note: 'Our home base' },
  { name: 'Frisco', county: 'Collin County' },
  { name: 'McKinney', county: 'Collin County' },
  { name: 'Celina', county: 'Collin County' },
  { name: 'Little Elm', county: 'Denton County' },
  { name: 'Aubrey', county: 'Denton County' },
  { name: 'The Colony', county: 'Denton County' },
];
---

<Layout
  title={`Service Area | ${business.name} | North DFW Poop Scooping`}
  description="Doodie Crew serves Prosper, Frisco, McKinney, Celina, Little Elm, Aubrey & The Colony with professional pet waste removal. No contracts."
>

  <Nav
    businessName={business.name}
    phone={business.phone}
    links={business.nav}
    ctaHref={business.ctaHref}
  />

  <CoverageDetails
    eyebrow="Our Coverage"
    heading="Professional poop scooping throughout North DFW."
    body="Doodie Crew serves the fast-growing communities of Collin and Denton County, from our home base in Prosper to Frisco, McKinney, Celina, and beyond. Every yard in our service area gets the same reliable pet waste removal, all-weather service, and 100% satisfaction guarantee. No second-tier service based on your zip code."
    radius="Collin & Denton County"
    centerCity="Prosper, TX"
    responseTime="Scheduled weekly or bi-weekly"
    features={[
      'Consistent service regardless of which city you live in',
      'Same pricing across our entire coverage area',
      'All-weather visits: rain, heat, or cold',
      'Organic kennel-grade disinfectant on every tool, every yard',
      'Online portal to manage your schedule anytime',
      'Locally owned and operated out of Prosper, TX',
    ]}
  />

  <CityGrid
    eyebrow="Where We Scoop"
    heading="Cities and communities we serve."
    subtext="Every neighborhood in our coverage area gets the same professional dog waste removal, reliable scheduling, all-weather visits, and no long-term contracts."
    cities={cities}
  />

  <section class="bg-[#FBF8F3] py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-heading text-2xl text-[#1A2540] mb-4">Explore poop scooping services by city:</h2>
      <ul class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <li>
          <a href="/service-area/prosper" class="text-[#1B5FBF] font-body hover:underline font-medium">
            Poop Scooping in Prosper
          </a>
        </li>
        <li>
          <a href="/service-area/frisco" class="text-[#1B5FBF] font-body hover:underline font-medium">
            Poop Scooping in Frisco
          </a>
        </li>
        <li>
          <a href="/service-area/mckinney" class="text-[#1B5FBF] font-body hover:underline font-medium">
            Poop Scooping in McKinney
          </a>
        </li>
        <li>
          <a href="/service-area/celina" class="text-[#1B5FBF] font-body hover:underline font-medium">
            Poop Scooping in Celina
          </a>
        </li>
        <li>
          <a href="/service-area/little-elm" class="text-[#1B5FBF] font-body hover:underline font-medium">
            Poop Scooping in Little Elm
          </a>
        </li>
        <li>
          <a href="/service-area/aubrey" class="text-[#1B5FBF] font-body hover:underline font-medium">
            Poop Scooping in Aubrey
          </a>
        </li>
        <li>
          <a href="/service-area/the-colony" class="text-[#1B5FBF] font-body hover:underline font-medium">
            Poop Scooping in The Colony
          </a>
        </li>
      </ul>
    </div>
  </section>

  <CallToAction
    eyebrow="Serving Your Neighborhood?"
    heading="Professional pet waste removal near you."
    subtext="Check if we cover your street. Most of North DFW is in our service zone. Start with an instant quote or give us a call."
    phone={business.phone}
    ctaLabel="Get an Instant Quote"
    ctaHref={business.ctaHref}
  />

  <Footer
    businessName={business.name}
    tagline={business.tagline}
    phone={business.phone}
    email={business.email}
    address={business.address.full}
    links={business.nav}
    serviceAreas={business.serviceAreas}
    social={business.social}
  />

</Layout>
