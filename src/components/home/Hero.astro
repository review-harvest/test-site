---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  eyebrow?: string;
  headline?: string;
  subtext?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  stats?: Stat[];
}

const {
  eyebrow = 'Licensed & Insured',
  headline = 'Your Business Name',
  subtext = 'Professional service you can count on. We show up on time, do the job right, and stand behind our work.',
  primaryCta = { label: 'Get a Free Quote', href: '/contact' },
  secondaryCta = { label: 'Our Services', href: '/services' },
  stats = [
    { value: '20+', label: 'Years in Business' },
    { value: '500+', label: 'Jobs Completed' },
    { value: '4.9★', label: 'Google Rating' },
  ],
} = Astro.props;
---

<section class="relative bg-surface overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-16 lg:py-24 pb-20">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-center">

      <!-- Content -->
      <div class="lg:col-span-7 xl:col-span-6">

        {eyebrow && (
          <div class="inline-flex items-center gap-2.5 mb-6">
            <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
            <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
              {eyebrow}
            </span>
          </div>
        )}

        <h1 class="font-heading text-3xl lg:text-hero text-text leading-tight lg:leading-none">
          {headline}
        </h1>

        <p class="font-body text-lg text-text-soft mt-6 leading-relaxed max-w-lg">
          {subtext}
        </p>

        <div class="flex flex-wrap gap-3 mt-8">
          <a
            href={primaryCta.href}
            class="inline-flex items-center justify-center font-body font-bold text-base px-7 py-3.5 rounded-md shadow-sm hover:opacity-90 transition-opacity"
            style="background-color: #E8951A; color: #ffffff;"
          >
            {primaryCta.label}
          </a>
          {secondaryCta && (
            <a
              href={secondaryCta.href}
              class="inline-flex items-center justify-center font-body font-semibold text-base px-7 py-3.5 rounded-md border-2 hover:opacity-80 transition-opacity"
              style="border-color: #1B5FBF; color: #1B5FBF;"
            >
              {secondaryCta.label}
            </a>
          )}
        </div>


      </div>

      <!-- Image -->
      <div class="lg:col-span-5 xl:col-span-6">
        <div class="relative">

          <!-- Hero photo: Doodie Crew team member with branded truck -->
          <div class="aspect-[5/4] rounded-lg overflow-hidden shadow-md">
            <img
              src="/images/doodie-crew-employee-truck-dog-waste-service-dfw-tx.jpg"
              alt="Doodie Crew team member in orange uniform standing in front of the branded Ford Maverick dog waste removal truck in DFW, TX"
              class="w-full h-full object-cover object-center"
              loading="eager"
            />
          </div>

          <!-- Floating accent card: amber brand color -->
          <div class="absolute -bottom-5 -left-5 hidden lg:block bg-surface rounded-lg shadow-md border border-border p-4">
            <p class="font-body text-xs font-semibold tracking-wider uppercase text-text-soft">Starts at</p>
            <p class="font-heading text-xl text-text mt-0.5" style="color: #E8951A;">$52 / month</p>
          </div>

          <!-- Decorative circle: amber tint -->
          <div class="absolute -top-4 -right-4 w-20 h-20 rounded-full bg-brand-tint -z-10" aria-hidden="true"></div>

        </div>
      </div>

    </div>
  </div>
  <!-- Wave: white → cream Services section -->
  <div class="absolute bottom-0 left-0 right-0 pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 1440 64" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block;width:100%;height:64px;">
      <path d="M0,32 C240,64 480,0 720,32 C960,64 1200,0 1440,32 L1440,64 L0,64 Z" fill="#FEFAF4"/>
    </svg>
  </div>
</section>
