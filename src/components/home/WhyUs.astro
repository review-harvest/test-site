---
interface Feature {
  title: string;
  description: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  body?: string;
  features?: Feature[];
  ctaHref?: string;
}

const {
  eyebrow = 'Why Choose Us',
  heading = 'The right team for the job.',
  body = "We've been serving this community for over two decades. Our reputation is built on doing the job right, being honest about what you need, and showing up when we say we will.",
  features = [
    { title: 'Upfront Pricing', description: 'No surprise charges. You get a full written quote before any work begins.' },
    { title: 'Same-Day Service', description: 'Most jobs completed the same day you call. We respect your time.' },
    { title: 'Fully Licensed', description: 'All technicians are licensed, background-checked, and insured.' },
    { title: 'Guaranteed Work', description: 'Every job comes with our satisfaction guarantee — we make it right.' },
  ],
  ctaHref = '/contact',
} = Astro.props;
---

<section class="bg-surface py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">

      <!-- Left: statement (sticky on scroll) -->
      <div class="lg:col-span-5 lg:sticky lg:top-28">
        {eyebrow && (
          <div class="inline-flex items-center gap-2.5 mb-4">
            <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
            <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
              {eyebrow}
            </span>
          </div>
        )}

        <h2 class="font-heading text-3xl text-text leading-tight">{heading}</h2>

        <p class="font-body text-base text-text-soft mt-5 leading-relaxed">{body}</p>

        <a
          href={ctaHref}
          class="inline-flex items-center gap-2 mt-8 font-body text-sm font-semibold text-brand hover:gap-3 transition-all duration-150"
        >
          Talk to us today
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <!-- Right: feature grid -->
      <div class="lg:col-span-7">
        <div class="grid sm:grid-cols-2 gap-8">
          {features.map((feature) => (
            <div class="border-t-2 border-brand/20 pt-6">
              <div class="w-2 h-2 rounded-full bg-brand mb-4" aria-hidden="true"></div>
              <h3 class="font-body font-semibold text-base text-text">{feature.title}</h3>
              <p class="font-body text-sm text-text-soft mt-2 leading-relaxed">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
