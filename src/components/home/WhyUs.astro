---
interface Props {
  ctaHref?: string;
}
const { ctaHref = '#' } = Astro.props;

const bullets = [
  { emoji: '📸', text: 'Photo of your secured gate after every visit. We never leave it open.' },
  { emoji: '🚛', text: 'Clean, marked truck you\'ll recognize at the curb' },
  { emoji: '💩', text: 'All waste bagged and fully removed from your property' },
  { emoji: '⭐', text: '5-star rated by Prosper & DFW families' },
  { emoji: '📲', text: 'You\'ll be notified when your yard is fresh and clean' },
  { emoji: '🔔', text: 'We\'ll alert you if we notice anything unusual with your dog' },
  { emoji: '🐾', text: 'Owned by a K-9 handler & certified dog trainer' },
  { emoji: '🌿', text: 'Pet-safe, eco-friendly monthly deodorizing available' },
  { emoji: '🚫', text: 'No contracts. Pause or cancel anytime, no fees' },
  { emoji: '👍', text: 'Satisfaction guaranteed. Free re-scoop if we miss a spot' },
];
---

<section class="bg-[#F4F4F2] py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Heading -->
    <div class="text-center mb-10">
      <h2 class="font-heading text-4xl lg:text-5xl font-black text-[#1A2540]">Why DFW Homeowners Choose Doodie Crew for Poop Scooping</h2>
      <div class="flex items-center justify-center mt-3" aria-hidden="true">
        <svg width="80" height="14" viewBox="0 0 80 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M2 7 Q10 2, 20 7 Q30 12, 40 7 Q50 2, 60 7 Q70 12, 78 7" stroke="#E8951A" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        </svg>
      </div>
    </div>

    <!-- Bullets + truck side by side -->
    <div class="flex flex-col lg:flex-row items-center lg:items-end gap-10 lg:gap-6">

      <!-- Bullet grid -->
      <div class="flex-1 grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-4">
        {bullets.map((b) => (
          <div class="flex items-start gap-3">
            <span class="text-2xl leading-none mt-0.5 shrink-0" aria-hidden="true">{b.emoji}</span>
            <span class="font-body text-[15px] font-semibold text-[#1A2540] leading-snug">{b.text}</span>
          </div>
        ))}
      </div>

      <!-- Truck column: slide in from right, overflow clip scoped to this column -->
      <div class="truck-col lg:w-[50%] shrink-0 overflow-hidden">
        <div class="truck-anim">
          <img
            src="/images/truck-cutout.png"
            alt="Doodie Crew branded truck in Prosper, TX"
            class="truck-img w-full"
            loading="lazy"
            width="2176"
            height="1084"
            draggable="false"
          />
        </div>
      </div>

    </div>

    <!-- Team photo strip -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-12">
      <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-md">
        <img
          src="/images/ryan-white-owner-doodie-crew-poop-scooping-prosper-tx.jpg"
          alt="Ryan White, owner of Doodie Crew, in an orange hoodie standing next to the branded dog waste removal truck in Prosper, TX"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
      <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-md">
        <img
          src="/images/doodie-crew-branded-uniform-dog-waste-removal-tx.jpg"
          alt="Doodie Crew team member in orange uniform scooping dog waste with a yellow collection bin against a stone wall in a residential backyard in TX"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
      <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-md">
        <img
          src="/images/doodie-crew-yard-cleanup-pet-waste-removal-prosper-tx.jpg"
          alt="Back view of Doodie Crew team member in branded orange shirt reading 'I Want Your Dog Doodie' during a yard cleanup visit in Prosper, TX"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
    </div>

  </div>
</section>

<style>
  .truck-anim {
    transform: translateX(110%);
    transition: transform 1.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .truck-anim.truck-visible {
    transform: translateX(0);
  }
  .truck-img {
    filter: drop-shadow(0 8px 24px rgba(0,0,0,0.18));
    display: block;
    width: 100%;
  }
</style>

<script>
  (function () {
    const anim = document.querySelector('.truck-anim') as HTMLElement | null;
    const trigger = document.querySelector('.truck-col') as HTMLElement | null;
    if (!anim || !trigger) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            anim.classList.add('truck-visible');
            observer.disconnect();
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(trigger);
  })();
</script>
