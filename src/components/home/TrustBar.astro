---
interface Item {
  value: string;
  label: string;
}

interface Props {
  items?: Item[];
}

const {
  items = [
    { value: '20+', label: 'Years Experience' },
    { value: '1,200+', label: 'Jobs Completed' },
    { value: '4.9 / 5', label: 'Google Rating' },
    { value: '24/7', label: 'Emergency Service' },
  ],
} = Astro.props;
---

<div style="background-color: #1A2540;">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-px rounded-lg overflow-hidden" style="background-color: rgba(255,255,255,0.08);">
      {items.map((item) => (
        <div class="px-6 py-5 text-center" style="background-color: #1A2540;">
          <p class="font-heading text-2xl leading-none font-bold" style="color: #E8951A;">{item.value}</p>
          <p class="font-body text-sm mt-1.5 font-medium" style="color: rgba(255,255,255,0.65);">{item.label}</p>
        </div>
      ))}
    </div>
  </div>
</div>
