---
interface Testimonial {
  quote: string;
  name: string;
  location: string;
  rating?: number;
  service?: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  testimonials?: Testimonial[];
}

const {
  eyebrow = 'Customer Reviews',
  heading = "Don't take our word for it.",
  testimonials = [
    {
      quote: 'They came out same day and fixed the problem in under two hours. Fair price, clean work, and the technician explained everything he was doing.',
      name: 'Sarah M.',
      location: 'Austin, TX',
      rating: 5,
    },
    {
      quote: "I've used three other companies in this city and none of them compare. Honest, fast, and they actually answer the phone. Won't call anyone else.",
      name: 'James P.',
      location: 'Round Rock, TX',
      rating: 5,
    },
    {
      quote: 'Called on a Sunday morning with an emergency. They were here within 90 minutes. Saved us from a much bigger problem. Highly recommend.',
      name: 'Linda K.',
      location: 'Cedar Park, TX',
      rating: 5,
    },
  ],
} = Astro.props;
---

<section id="reviews" class="bg-bg py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Section header: centered with flanking lines -->
    <div class="text-center max-w-xl mx-auto mb-12">
      {eyebrow && (
        <div class="inline-flex items-center justify-center gap-2.5 mb-4">
          <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
          <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
            {eyebrow}
          </span>
          <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
        </div>
      )}
      <h2 class="font-heading text-3xl text-text leading-tight">{heading}</h2>
    </div>

    <!-- Review cards -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
      {testimonials.map((t) => (
        <div class="bg-surface border border-border rounded-lg p-7 flex flex-col hover:shadow-md transition-shadow duration-200">

          <!-- Star rating -->
          <div class="flex gap-0.5 mb-5" aria-label={`${t.rating ?? 5} out of 5 stars`}>
            {Array.from({ length: t.rating ?? 5 }).map(() => (
              <svg class="w-4 h-4 text-brand shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote in serif for warmth -->
          <blockquote class="font-heading text-lg text-text leading-snug flex-1">
            "{t.quote}"
          </blockquote>

          <!-- Reviewer info -->
          <div class="mt-6 pt-5 border-t border-border">
            <p class="font-body font-semibold text-sm text-text">{t.name}</p>
            <div class="flex items-center justify-between mt-0.5">
              <p class="font-body text-sm text-text-soft">{t.location}</p>
              {t.service && (
                <span class="font-body text-xs text-brand bg-brand-tint px-2 py-0.5 rounded-sm">
                  {t.service}
                </span>
              )}
            </div>
          </div>

        </div>
      ))}
    </div>

    <!-- Link to full reviews page -->
    <div class="mt-10 text-center">
      <a
        href="/reviews"
        class="inline-flex items-center gap-2 font-body text-sm font-semibold text-brand hover:gap-3 transition-all duration-150"
      >
        Read all reviews
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
