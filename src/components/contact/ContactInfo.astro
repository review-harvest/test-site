---
interface HoursRow {
  days: string;
  time: string;
}

interface Props {
  phone?: string;
  email?: string;
  address?: string;
  hours?: HoursRow[];
}

const {
  phone = '(555) 000-0000',
  email = 'hello@example.com',
  address = '123 Main St, City, ST 00000',
  hours = [
    { days: 'Monday – Friday', time: '7:30 am – 6:00 pm' },
  ],
} = Astro.props;

const phoneHref = 'tel:+1' + phone.replace(/\D/g, '');
---

<div class="space-y-8">

  <!-- Phone -->
  <div>
    <p class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft mb-3">Phone</p>
    <a
      href={phoneHref}
      class="inline-flex items-center gap-2.5 font-heading text-2xl text-text hover:text-brand transition-colors"
      aria-label={`Call us at ${phone}`}
    >
      <svg class="w-5 h-5 text-brand shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
      </svg>
      {phone}
    </a>
  </div>

  <div class="h-px bg-border"></div>

  <!-- Email -->
  <div>
    <p class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft mb-3">Email</p>
    <a
      href={`mailto:${email}`}
      class="inline-flex items-center gap-2.5 font-body text-base font-semibold text-text hover:text-brand transition-colors"
    >
      <svg class="w-4 h-4 text-brand shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
      </svg>
      {email}
    </a>
  </div>

  <div class="h-px bg-border"></div>

  <!-- Address -->
  <div>
    <p class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft mb-3">Location</p>
    <div class="flex items-start gap-2.5">
      <svg class="w-4 h-4 text-brand shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
      </svg>
      <p class="font-body text-base text-text">{address}</p>
    </div>
  </div>

  <div class="h-px bg-border"></div>

  <!-- Hours -->
  <div>
    <p class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft mb-3">Business Hours</p>
    <ul class="space-y-2.5">
      {hours.map((row) => (
        <li class="flex items-center justify-between gap-4">
          <span class="font-body text-sm text-text">{row.days}</span>
          <span class="font-body text-sm font-medium text-text shrink-0">{row.time}</span>
        </li>
      ))}
    </ul>
  </div>

  <div class="h-px bg-border"></div>

  <!-- Map embed -->
  <div>
    <p class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft mb-3">Service Area</p>
    <div class="rounded-lg overflow-hidden border border-border">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d330788.21462725627!2d-96.72806920000001!3d33.20137855!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x849cdd8426390b7d%3A0xd03112d08e7c74bd!2sDoodie%20Crew%20Poop%20Scooping!5e1!3m2!1sen!2sus!4v1775560994504!5m2!1sen!2sus"
        width="100%"
        height="300"
        style="border:0; display:block;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Doodie Crew Poop Scooping service area map"
      ></iframe>
    </div>
    <a href="/service-area" class="font-body text-sm text-brand font-medium mt-2 inline-block hover:underline">
      View full service area →
    </a>
  </div>

</div>
