---
interface HoursRow {
  days: string;
  time: string;
}

interface Props {
  phone?: string;
  email?: string;
  address?: string;
  hours?: HoursRow[];
}

const {
  phone = '(555) 000-0000',
  email = 'hello@example.com',
  address = '123 Main St, City, ST 00000',
  hours = [
    { days: 'Monday – Friday', time: '7:00 am – 7:00 pm' },
    { days: 'Saturday', time: '8:00 am – 5:00 pm' },
    { days: 'Sunday', time: 'Emergency calls only' },
  ],
} = Astro.props;

const phoneHref = 'tel:+1' + phone.replace(/\D/g, '');
---

<div class="space-y-8">

  <!-- Phone -->
  <div>
    <p class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft mb-3">Phone</p>
    <a
      href={phoneHref}
      class="inline-flex items-center gap-2.5 font-heading text-2xl text-text hover:text-brand transition-colors"
      aria-label={`Call us at ${phone}`}
    >
      <svg class="w-5 h-5 text-brand shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
      </svg>
      {phone}
    </a>
    <p class="font-body text-sm text-text-soft mt-1.5 ml-7.5">
      Emergency line available 24/7. Press 1 when prompted.
    </p>
  </div>

  <div class="h-px bg-border"></div>

  <!-- Email -->
  <div>
    <p class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft mb-3">Email</p>
    <a
      href={`mailto:${email}`}
      class="inline-flex items-center gap-2.5 font-body text-base font-semibold text-text hover:text-brand transition-colors"
    >
      <svg class="w-4 h-4 text-brand shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
      </svg>
      {email}
    </a>
  </div>

  <div class="h-px bg-border"></div>

  <!-- Address -->
  <div>
    <p class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft mb-3">Location</p>
    <div class="flex items-start gap-2.5">
      <svg class="w-4 h-4 text-brand shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
      </svg>
      <p class="font-body text-base text-text">{address}</p>
    </div>
  </div>

  <div class="h-px bg-border"></div>

  <!-- Hours -->
  <div>
    <p class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft mb-3">Business Hours</p>
    <ul class="space-y-2.5">
      {hours.map((row) => (
        <li class="flex items-center justify-between gap-4">
          <span class="font-body text-sm text-text">{row.days}</span>
          <span class="font-body text-sm font-medium text-text shrink-0">{row.time}</span>
        </li>
      ))}
    </ul>
  </div>

  <div class="h-px bg-border"></div>

  <!-- Map placeholder -->
  <div>
    <p class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft mb-3">Service Area</p>
    <div class="aspect-[4/3] rounded-lg bg-brand-tint border border-border flex items-center justify-center">
      <div class="text-center">
        <svg class="w-8 h-8 text-brand/30 mx-auto" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
        </svg>
        <p class="font-body text-sm text-text-soft mt-2">North DFW Metroplex</p>
        <a href="/service-area" class="font-body text-sm text-brand font-medium mt-1 inline-block hover:underline">
          View full service area →
        </a>
      </div>
    </div>
  </div>

</div>
