---
interface RatingBreakdown {
  stars: number;
  count: number;
  pct: number;
}

interface Props {
  rating?: string;
  totalReviews?: number;
  breakdown?: RatingBreakdown[];
}

const {
  rating = '4.9',
  totalReviews = 847,
  breakdown = [
    { stars: 5, count: 728, pct: 86 },
    { stars: 4, count: 94, pct: 11 },
    { stars: 3, count: 17, pct: 2 },
    { stars: 2, count: 5, pct: 1 },
    { stars: 1, count: 3, pct: 0 },
  ],
} = Astro.props;
---

<section class="bg-surface border-b border-border py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">

      <!-- Big rating display -->
      <div class="lg:col-span-4 text-center lg:text-left">
        <p class="font-heading leading-none text-text" style="font-size: 6rem;">{rating}</p>
        <!-- Stars row -->
        <div class="flex items-center justify-center lg:justify-start gap-1 mt-2" aria-label={`${rating} out of 5 stars`}>
          {[1,2,3,4,5].map((n) => (
            <svg class="w-6 h-6 text-brand" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <p class="font-body text-sm text-text-soft mt-3">
          Based on <strong class="text-text font-semibold">{totalReviews.toLocaleString()}</strong> verified reviews
        </p>
      </div>

      <!-- Divider (lg) -->
      <div class="hidden lg:block lg:col-span-1">
        <div class="h-full w-px bg-border mx-auto"></div>
      </div>

      <!-- Rating breakdown bars -->
      <div class="lg:col-span-5 space-y-3">
        {breakdown.map((row) => (
          <div class="flex items-center gap-3">
            <span class="font-body text-sm text-text-soft w-8 shrink-0 text-right">{row.stars}★</span>
            <div class="flex-1 h-2 bg-border rounded-full overflow-hidden">
              <div
                class="h-full bg-brand rounded-full transition-all"
                style={`width: ${row.pct}%`}
                role="progressbar"
                aria-valuenow={row.pct}
                aria-valuemin={0}
                aria-valuemax={100}
                aria-label={`${row.stars} star reviews: ${row.pct}%`}
              ></div>
            </div>
            <span class="font-body text-sm text-text-soft w-8 shrink-0">{row.pct}%</span>
          </div>
        ))}
      </div>

      <!-- Platform badges -->
      <div class="lg:col-span-2 flex flex-row lg:flex-col gap-3 justify-center lg:justify-start">
        <div class="flex-1 lg:flex-none flex flex-col items-center p-4 bg-brand-tint rounded-lg border border-brand/15 text-center">
          <p class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft mb-1">Google</p>
          <p class="font-heading text-xl text-text">4.9★</p>
          <p class="font-body text-xs text-text-soft mt-0.5">847 reviews</p>
        </div>
        <div class="flex-1 lg:flex-none flex flex-col items-center p-4 bg-surface rounded-lg border border-border text-center">
          <p class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft mb-1">Yelp</p>
          <p class="font-heading text-xl text-text">4.8★</p>
          <p class="font-body text-xs text-text-soft mt-0.5">312 reviews</p>
        </div>
      </div>

    </div>
  </div>
</section>
