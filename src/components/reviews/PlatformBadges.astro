---
interface Platform {
  name: string;
  rating: string;
  reviewCount: number;
  url?: string;
  description?: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  platforms?: Platform[];
}

const {
  eyebrow = 'Verified On',
  heading = 'Find us on every major review platform.',
  platforms = [
    {
      name: 'Google',
      rating: '4.9',
      reviewCount: 847,
      url: '#',
      description: 'Our primary review profile. Search "Apex Plumbing Austin" to verify.',
    },
    {
      name: 'Yelp',
      rating: '4.8',
      reviewCount: 312,
      url: '#',
      description: 'Hundreds of detailed reviews from verified Yelp customers.',
    },
    {
      name: 'Angi',
      rating: '4.9',
      reviewCount: 184,
      url: '#',
      description: 'Angi Super Service Award winner. Verified contractor profile.',
    },
  ],
} = Astro.props;
---

<section class="bg-surface border-b border-border py-16">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Section header -->
    <div class="text-center mb-10">
      {eyebrow && (
        <div class="inline-flex items-center justify-center gap-2.5 mb-3">
          <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
          <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
            {eyebrow}
          </span>
          <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
        </div>
      )}
      <h2 class="font-heading text-2xl text-text leading-tight">{heading}</h2>
    </div>

    <!-- Platform cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
      {platforms.map((platform) => (
        <div class="bg-bg border border-border rounded-lg p-7 text-center shadow-sm hover:shadow-md transition-shadow duration-200">

          <!-- Platform name pill -->
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-tint border border-brand/20 mb-5">
            <span class="font-body text-xs font-bold text-brand">{platform.name.slice(0, 2).toUpperCase()}</span>
          </div>

          <p class="font-body font-semibold text-base text-text">{platform.name}</p>

          <!-- Rating display -->
          <div class="flex items-center justify-center gap-1.5 mt-2 mb-1">
            <span class="font-heading text-3xl text-text leading-none">{platform.rating}</span>
            <svg class="w-5 h-5 text-brand shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          </div>
          <p class="font-body text-sm text-text-soft">
            {platform.reviewCount.toLocaleString()} reviews
          </p>

          {platform.description && (
            <p class="font-body text-sm text-text-soft mt-3 leading-relaxed">{platform.description}</p>
          )}

          {platform.url && (
            <a
              href={platform.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 mt-5 font-body text-sm font-semibold text-brand hover:gap-2.5 transition-all duration-150"
            >
              Read reviews
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          )}

        </div>
      ))}
    </div>

  </div>
</section>
