---
interface Review {
  quote: string;
  name: string;
  location: string;
  rating?: number;
  service?: string;
  date?: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  reviews?: Review[];
}

const {
  eyebrow = 'What Our Customers Say',
  heading = 'Real reviews from real customers.',
  reviews = [],
} = Astro.props;
---

<section class="bg-bg py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Section header -->
    <div class="max-w-2xl mb-12">
      {eyebrow && (
        <div class="inline-flex items-center gap-2.5 mb-4">
          <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
          <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
            {eyebrow}
          </span>
        </div>
      )}
      <h2 class="font-heading text-3xl text-text leading-tight">{heading}</h2>
    </div>

    <!-- Review grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {reviews.map((review) => (
        <article class="bg-surface border border-border rounded-lg p-7 flex flex-col hover:shadow-md transition-shadow duration-200">

          <!-- Header: stars + platform indicator -->
          <div class="flex items-start justify-between mb-5">
            <div class="flex gap-0.5" aria-label={`${review.rating ?? 5} out of 5 stars`}>
              {Array.from({ length: review.rating ?? 5 }).map(() => (
                <svg class="w-4 h-4 text-brand shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            {review.date && (
              <span class="font-body text-xs text-text-soft">{review.date}</span>
            )}
          </div>

          <!-- Quote -->
          <blockquote class="font-heading text-lg text-text leading-snug flex-1">
            "{review.quote}"
          </blockquote>

          <!-- Footer -->
          <div class="mt-6 pt-5 border-t border-border">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="font-body font-semibold text-sm text-text">{review.name}</p>
                <p class="font-body text-sm text-text-soft">{review.location}</p>
              </div>
              {review.service && (
                <span class="font-body text-xs text-brand bg-brand-tint px-2.5 py-1 rounded-sm shrink-0">
                  {review.service}
                </span>
              )}
            </div>
          </div>

        </article>
      ))}
    </div>

  </div>
</section>
