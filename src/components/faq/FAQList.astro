---
/**
 * FAQList — categorized accordion FAQ using native <details>/<summary>.
 * No JavaScript required; fully accessible and keyboard-navigable.
 */
interface Question {
  question: string;
  answer: string;
}

interface FAQCategory {
  category: string;
  questions: Question[];
}

interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  categories?: FAQCategory[];
  titleLevel?: 'h1' | 'h2';
}

const {
  eyebrow = 'Common Questions',
  heading = 'Everything you need to know.',
  subtext = "Can't find your answer here? Call us — we're happy to help.",
  categories = [],
  titleLevel = 'h2',
} = Astro.props;
---

<section class="bg-bg py-20 lg:py-28">
  <div class="max-w-4xl mx-auto px-6 lg:px-10">

    <!-- Section header -->
    <div class="text-center mb-14">
      {eyebrow && (
        <div class="inline-flex items-center justify-center gap-2.5 mb-4">
          <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
          <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
            {eyebrow}
          </span>
          <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
        </div>
      )}
      {titleLevel === 'h1'
        ? <h1 class="font-heading text-3xl text-text leading-tight">{heading}</h1>
        : <h2 class="font-heading text-3xl text-text leading-tight">{heading}</h2>
      }
      {subtext && (
        <p class="font-body text-base text-text-soft mt-3 leading-relaxed">{subtext}</p>
      )}
    </div>

    <!-- FAQ categories -->
    <div class="space-y-12">
      {categories.map((cat) => (
        <div>
          <!-- Category heading -->
          <h3 class="font-body text-xs font-semibold tracking-widest uppercase text-text-soft pb-4 border-b border-border mb-2">
            {cat.category}
          </h3>

          <!-- Accordion items -->
          <div class="divide-y divide-border">
            {cat.questions.map((item) => (
              <details class="group py-5">
                <summary class="flex items-start justify-between gap-4 cursor-pointer list-none">
                  <span class="font-body font-semibold text-base text-text group-open:text-brand transition-colors pr-2">
                    {item.question}
                  </span>
                  <!-- Plus / minus toggle icon -->
                  <span class="shrink-0 mt-0.5" aria-hidden="true">
                    <svg
                      class="w-5 h-5 text-text-soft group-open:rotate-45 transition-transform duration-200"
                      fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                  </span>
                </summary>
                <p class="font-body text-base text-text-soft mt-3 leading-relaxed pr-9">
                  {item.answer}
                </p>
              </details>
            ))}
          </div>

        </div>
      ))}
    </div>

    <!-- CTA nudge -->
    <div class="mt-14 text-center p-8 bg-surface rounded-lg border border-border">
      <p class="font-body text-base text-text font-medium">Still have questions?</p>
      <p class="font-body text-sm text-text-soft mt-1 mb-5">We're happy to talk through your specific situation over the phone.</p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href="tel:+15125550142"
          class="inline-flex items-center gap-2 bg-brand text-brand-fg font-body font-semibold text-sm px-5 py-3 rounded-md hover:opacity-90 transition-opacity"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          Call Us Now
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 font-body font-semibold text-sm text-text border border-border px-5 py-3 rounded-md hover:border-brand hover:text-brand transition-colors"
        >
          Send a Message
        </a>
      </div>
    </div>

  </div>
</section>
