---
/**
 * ServiceDetail — full service description section for individual service pages.
 * Appears near the top of each service page, after the PageHero.
 */
interface Props {
  name: string;
  tagline?: string;
  description: string;
  benefits?: string[];
  guarantee?: string;
}

const {
  name,
  tagline = 'Professional service, done right.',
  description,
  benefits = [],
  guarantee = 'All work is backed by our 1-year labor warranty.',
} = Astro.props;
---

<section class="bg-surface py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">

      <!-- Content -->
      <div class="lg:col-span-6">
        <p class="font-body text-sm font-semibold tracking-widest uppercase text-brand mb-3">
          {tagline}
        </p>

        <h1 class="font-heading text-3xl text-text leading-tight">{name}</h1>

        <p class="font-body text-base text-text-soft mt-5 leading-relaxed">
          {description}
        </p>

        <!-- Benefits / what's included -->
        {benefits.length > 0 && (
          <ul class="mt-8 space-y-3">
            {benefits.map((benefit) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-brand-tint border border-brand/20 flex items-center justify-center">
                  <svg class="w-3 h-3 text-brand" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                </span>
                <span class="font-body text-base text-text">{benefit}</span>
              </li>
            ))}
          </ul>
        )}

        <!-- Guarantee badge -->
        {guarantee && (
          <div class="mt-8 flex items-start gap-3 p-4 bg-brand-tint rounded-lg border border-brand/15">
            <svg class="w-5 h-5 text-brand shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
            <p class="font-body text-sm font-medium text-text">{guarantee}</p>
          </div>
        )}

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 mt-8">
          <a
            href="/contact"
            class="inline-flex items-center justify-center bg-brand text-brand-fg
                   font-body font-semibold text-base px-7 py-3.5 rounded-md shadow-sm
                   hover:opacity-90 transition-opacity"
          >
            Get a Free Quote
          </a>
          <a
            href="tel:+15125550142"
            class="inline-flex items-center gap-2 justify-center text-text
                   font-body font-medium text-base px-7 py-3.5 rounded-md
                   border border-border hover:border-brand hover:text-brand transition-colors"
          >
            <svg class="w-4 h-4 text-brand shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            Call Now
          </a>
        </div>
      </div>

      <!-- Image placeholder -->
      <div class="lg:col-span-6">
        <div class="relative">
          <div class="aspect-[4/3] rounded-lg bg-brand-tint overflow-hidden shadow-md">
            <div class="w-full h-full flex flex-col items-center justify-center gap-3">
              <svg class="w-14 h-14 text-brand/20" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <p class="font-body text-sm text-text-soft/40">{name} — project photo</p>
            </div>
          </div>
          <div class="absolute -top-4 -right-4 w-20 h-20 rounded-full bg-brand/5 -z-10" aria-hidden="true"></div>
        </div>
      </div>

    </div>
  </div>
</section>
