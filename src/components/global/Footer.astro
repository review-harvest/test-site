---
interface Props {
  businessName?: string;
  tagline?: string;
  phone?: string;
  email?: string;
  address?: string;
  links?: Array<{ label: string; href: string }>;
  serviceAreas?: string[];
}

const {
  businessName = 'Business Name',
  tagline = 'Serving our community with honest, reliable service since day one.',
  phone = '(555) 000-0000',
  email = 'hello@example.com',
  address = 'City, State',
  links = [
    { label: 'Services', href: '/services' },
    { label: 'About', href: '/about' },
    { label: 'Contact', href: '/contact' },
  ],
  serviceAreas = ['City A', 'City B', 'City C', 'City D', 'City E', 'City F'],
} = Astro.props;

const phoneHref = 'tel:+1' + phone.replace(/\D/g, '');
const year = new Date().getFullYear();
---

<footer class="bg-neutral-950">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 pt-16 pb-8">

    <!-- Top grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 pb-12 border-b border-white/10">

      <!-- Brand + contact -->
      <div class="lg:col-span-2">
        <p class="font-heading text-xl text-white">{businessName}</p>
        <p class="font-body text-sm text-white/50 mt-3 max-w-xs leading-relaxed">{tagline}</p>
        <div class="mt-5 space-y-2">
          <a
            href={phoneHref}
            class="flex items-center gap-2 font-body text-sm font-semibold text-white hover:text-brand-tint transition-colors w-fit"
          >
            <svg class="w-3.5 h-3.5 text-white/40 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            {phone}
          </a>
          {email && (
            <a
              href={`mailto:${email}`}
              class="flex items-center gap-2 font-body text-sm text-white/50 hover:text-white transition-colors w-fit"
            >
              <svg class="w-3.5 h-3.5 text-white/30 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              {email}
            </a>
          )}
          {address && (
            <p class="flex items-start gap-2 font-body text-sm text-white/40">
              <svg class="w-3.5 h-3.5 mt-0.5 text-white/25 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              {address}
            </p>
          )}
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <p class="font-body text-xs font-semibold tracking-widest uppercase text-white/30 mb-5">
          Quick Links
        </p>
        <ul class="space-y-3">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-body text-sm text-white/55 hover:text-white transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Service areas -->
      <div>
        <p class="font-body text-xs font-semibold tracking-widest uppercase text-white/30 mb-5">
          Service Areas
        </p>
        <ul class="space-y-3">
          {serviceAreas.map((area) => (
            <li class="font-body text-sm text-white/55">{area}</li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3 pt-8">
      <p class="font-body text-xs text-white/25">
        &copy; {year} {businessName}. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <a href="/faq" class="font-body text-xs text-white/25 hover:text-white/50 transition-colors">FAQ</a>
        <a href="/reviews" class="font-body text-xs text-white/25 hover:text-white/50 transition-colors">Reviews</a>
        <a href="/contact" class="font-body text-xs text-white/25 hover:text-white/50 transition-colors">Contact</a>
      </div>
    </div>

  </div>
</footer>
