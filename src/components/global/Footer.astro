---
interface Props {
  businessName?: string;
  tagline?: string;
  phone?: string;
  email?: string;
  address?: string;
  links?: Array<{ label: string; href: string }>;
  serviceAreas?: string[];
  social?: { facebook?: string; instagram?: string };
}

const {
  businessName = 'Business Name',
  tagline = 'Serving our community with honest, reliable service since day one.',
  phone = '(555) 000-0000',
  email = 'hello@example.com',
  address = 'City, State',
  links = [
    { label: 'Services', href: '/services' },
    { label: 'About', href: '/about' },
    { label: 'Contact', href: '/contact' },
  ],
  serviceAreas = ['City A', 'City B', 'City C', 'City D', 'City E', 'City F'],
  social = {},
} = Astro.props;

const phoneHref = 'tel:+1' + phone.replace(/\D/g, '');
const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden" style="background-color: #080F1E;">

  <!-- ── Decorative background accents ── -->

  <!-- Large paw print — bottom left -->
  <div class="absolute -bottom-6 -left-8 pointer-events-none select-none" aria-hidden="true"
       style="color: #E8951A; opacity: 0.045; transform: rotate(-18deg);">
    <svg viewBox="0 0 200 200" fill="currentColor" style="width:320px;height:320px;">
      <ellipse cx="60" cy="58" rx="22" ry="28"/>
      <ellipse cx="140" cy="58" rx="22" ry="28"/>
      <ellipse cx="27"  cy="115" rx="19" ry="24"/>
      <ellipse cx="173" cy="115" rx="19" ry="24"/>
      <ellipse cx="100" cy="152" rx="50" ry="43"/>
    </svg>
  </div>

  <!-- Medium paw print — top right -->
  <div class="absolute -top-4 -right-6 pointer-events-none select-none" aria-hidden="true"
       style="color: #E8951A; opacity: 0.035; transform: rotate(22deg);">
    <svg viewBox="0 0 200 200" fill="currentColor" style="width:220px;height:220px;">
      <ellipse cx="60" cy="58" rx="22" ry="28"/>
      <ellipse cx="140" cy="58" rx="22" ry="28"/>
      <ellipse cx="27"  cy="115" rx="19" ry="24"/>
      <ellipse cx="173" cy="115" rx="19" ry="24"/>
      <ellipse cx="100" cy="152" rx="50" ry="43"/>
    </svg>
  </div>

  <!-- Small paw print — center right -->
  <div class="absolute top-1/2 right-[12%] pointer-events-none select-none" aria-hidden="true"
       style="color: #E8951A; opacity: 0.028; transform: rotate(-8deg) translateY(-50%);">
    <svg viewBox="0 0 200 200" fill="currentColor" style="width:130px;height:130px;">
      <ellipse cx="60" cy="58" rx="22" ry="28"/>
      <ellipse cx="140" cy="58" rx="22" ry="28"/>
      <ellipse cx="27"  cy="115" rx="19" ry="24"/>
      <ellipse cx="173" cy="115" rx="19" ry="24"/>
      <ellipse cx="100" cy="152" rx="50" ry="43"/>
    </svg>
  </div>

  <!-- Dog bone — mid left -->
  <div class="absolute top-[30%] left-[6%] pointer-events-none select-none" aria-hidden="true"
       style="color: #E8951A; opacity: 0.03; transform: rotate(30deg);">
    <svg viewBox="0 0 120 44" fill="currentColor" style="width:180px;height:66px;">
      <circle cx="16" cy="11" r="11"/>
      <circle cx="16" cy="33" r="11"/>
      <circle cx="104" cy="11" r="11"/>
      <circle cx="104" cy="33" r="11"/>
      <rect x="16" y="14" width="88" height="16" rx="3"/>
    </svg>
  </div>

  <!-- Poop swirl — bottom center (fun branded accent) -->
  <div class="absolute bottom-8 left-1/2 pointer-events-none select-none" aria-hidden="true"
       style="color: #E8951A; opacity: 0.025; transform: translateX(-50%);">
    <svg viewBox="0 0 80 90" fill="currentColor" style="width:100px;height:112px;">
      <!-- stacked ovals = poop swirl -->
      <ellipse cx="40" cy="80" rx="36" ry="11"/>
      <ellipse cx="40" cy="68" rx="28" ry="11"/>
      <ellipse cx="40" cy="57" rx="22" ry="10"/>
      <ellipse cx="40" cy="47" rx="16" ry="9"/>
      <ellipse cx="40" cy="38" rx="11" ry="9"/>
      <ellipse cx="42" cy="28" rx="8"  ry="9"/>
      <ellipse cx="44" cy="19" rx="6"  ry="7"/>
      <ellipse cx="42" cy="12" rx="5"  ry="6"/>
    </svg>
  </div>

  <!-- Amber glow blob — top center -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-48 pointer-events-none" aria-hidden="true"
       style="background: radial-gradient(ellipse at top, rgba(232,149,26,0.06) 0%, transparent 70%);"></div>

  <!-- ── Footer content ── -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 pt-16 pb-8">

    <!-- Top grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 pb-12" style="border-bottom: 1px solid rgba(255,255,255,0.07);">

      <!-- Brand + contact -->
      <div class="lg:col-span-2">

        <!-- Logo + name -->
        <a href="/" class="inline-flex items-center gap-3 mb-5 group">
          <img
            src="/images/logo-dog-head.jpg"
            alt="Doodie Crew logo"
            class="w-12 h-12 rounded-xl object-cover shrink-0"
          />
          <div class="flex flex-col leading-none">
            <span class="font-heading text-lg font-black" style="color: #E8951A;">Doodie Crew</span>
            <span class="font-body text-[10px] font-semibold tracking-widest uppercase mt-0.5" style="color: rgba(255,255,255,0.35);">Poop Scooping</span>
          </div>
        </a>

        <p class="font-body text-sm leading-relaxed max-w-xs" style="color: rgba(255,255,255,0.45);">{tagline}</p>

        <div class="mt-5 space-y-2.5">
          <a
            href={phoneHref}
            class="flex items-center gap-2 font-body text-sm font-bold transition-colors w-fit"
            style="color: #E8951A;"
          >
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            {phone}
          </a>
          {email && (
            <a
              href={`mailto:${email}`}
              class="flex items-center gap-2 font-body text-sm transition-colors w-fit"
              style="color: rgba(255,255,255,0.45);"
            >
              <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true" style="color: rgba(255,255,255,0.25);">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              {email}
            </a>
          )}
          {address && (
            <p class="flex items-start gap-2 font-body text-sm" style="color: rgba(255,255,255,0.3);">
              <svg class="w-3.5 h-3.5 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true" style="color: rgba(255,255,255,0.2);">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              {address}
            </p>
          )}
        </div>

        <!-- Social links -->
        {(social.facebook || social.instagram) && (
          <div class="mt-6 flex items-center gap-3">
            {social.instagram && (
              <a
                href={social.instagram}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Doodie Crew on Instagram"
                class="w-9 h-9 rounded-lg flex items-center justify-center transition-colors"
                style="background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.5);"
                onmouseover="this.style.background='rgba(232,149,26,0.15)'; this.style.color='#E8951A'"
                onmouseout="this.style.background='rgba(255,255,255,0.07)'; this.style.color='rgba(255,255,255,0.5)'"
              >
                <!-- Instagram icon -->
                <svg class="w-4.5 h-4.5" style="width:18px;height:18px;" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
            )}
            {social.facebook && (
              <a
                href={social.facebook}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Doodie Crew on Facebook"
                class="w-9 h-9 rounded-lg flex items-center justify-center transition-colors"
                style="background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.5);"
                onmouseover="this.style.background='rgba(232,149,26,0.15)'; this.style.color='#E8951A'"
                onmouseout="this.style.background='rgba(255,255,255,0.07)'; this.style.color='rgba(255,255,255,0.5)'"
              >
                <!-- Facebook icon -->
                <svg class="w-4.5 h-4.5" style="width:18px;height:18px;" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            )}
            <a
              href="https://maps.app.goo.gl/AK7kYZjRA1gytiK28"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Doodie Crew on Google"
              class="w-9 h-9 rounded-lg flex items-center justify-center transition-colors"
              style="background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.5);"
              onmouseover="this.style.background='rgba(232,149,26,0.15)'; this.style.color='#E8951A'"
              onmouseout="this.style.background='rgba(255,255,255,0.07)'; this.style.color='rgba(255,255,255,0.5)'"
            >
              <!-- Google "G" icon -->
              <svg style="width:18px;height:18px;" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            </a>
          </div>
        )}
      </div>

      <!-- Quick links -->
      <div>
        <p class="font-body text-xs font-semibold tracking-widest uppercase mb-5" style="color: #E8951A; opacity: 0.75;">
          Quick Links
        </p>
        <ul class="space-y-3">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-body text-sm transition-colors hover:text-white"
                style="color: rgba(255,255,255,0.5);"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Service areas -->
      <div>
        <p class="font-body text-xs font-semibold tracking-widest uppercase mb-5" style="color: #E8951A; opacity: 0.75;">
          Service Areas
        </p>
        <ul class="space-y-3">
          {serviceAreas.map((area) => (
            <li class="font-body text-sm" style="color: rgba(255,255,255,0.5);">{area}</li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3 pt-7">
      <p class="font-body text-xs" style="color: rgba(255,255,255,0.2);">
        &copy; {year} {businessName}. All rights reserved.
      </p>
      <div class="flex items-center gap-5">
        <a href="/faq"     class="font-body text-xs transition-colors hover:text-white" style="color: rgba(255,255,255,0.2);">FAQ</a>
        <a href="/reviews" class="font-body text-xs transition-colors hover:text-white" style="color: rgba(255,255,255,0.2);">Reviews</a>
        <a href="/contact" class="font-body text-xs transition-colors hover:text-white" style="color: rgba(255,255,255,0.2);">Contact</a>
      </div>
    </div>

  </div>
</footer>
