---
interface Props {
  eyebrow?: string;
  heading?: string;
  subtext?: string;
  phone?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  eyebrow = 'Get Started Today',
  heading = 'Ready to get the job done right?',
  subtext = 'Call us for a free, no-obligation quote. We answer every call, 24 hours a day.',
  phone = '(555) 000-0000',
  ctaLabel = 'Request Online',
  ctaHref = '/contact',
} = Astro.props;

const phoneHref = 'tel:+1' + phone.replace(/\D/g, '');
---

<section class="relative overflow-hidden py-20 lg:py-28" style="background: linear-gradient(135deg, #0F1A35 0%, #1A2540 45%, #1B5FBF 100%);">

  <!-- Amber glow: top right -->
  <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full pointer-events-none"
       style="background: radial-gradient(circle, rgba(232,149,26,0.22) 0%, transparent 70%);"></div>

  <!-- Blue glow: bottom left -->
  <div class="absolute -bottom-24 -left-24 w-[30rem] h-[30rem] rounded-full pointer-events-none"
       style="background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 70%);"></div>

  <!-- Paw print: large, top-left -->
  <svg class="absolute -top-4 left-10 opacity-[0.055] pointer-events-none" style="transform: rotate(-25deg);"
       width="160" height="160" viewBox="0 0 100 100" fill="white" aria-hidden="true">
    <ellipse cx="50" cy="70" rx="22" ry="18"/>
    <ellipse cx="24" cy="48" rx="10" ry="13" transform="rotate(-18 24 48)"/>
    <ellipse cx="39" cy="33" rx="10" ry="13" transform="rotate(-6 39 33)"/>
    <ellipse cx="61" cy="33" rx="10" ry="13" transform="rotate(6 61 33)"/>
    <ellipse cx="76" cy="48" rx="10" ry="13" transform="rotate(18 76 48)"/>
  </svg>

  <!-- Paw print: medium, bottom-right -->
  <svg class="absolute bottom-6 right-16 opacity-[0.07] pointer-events-none" style="transform: rotate(20deg);"
       width="110" height="110" viewBox="0 0 100 100" fill="white" aria-hidden="true">
    <ellipse cx="50" cy="70" rx="22" ry="18"/>
    <ellipse cx="24" cy="48" rx="10" ry="13" transform="rotate(-18 24 48)"/>
    <ellipse cx="39" cy="33" rx="10" ry="13" transform="rotate(-6 39 33)"/>
    <ellipse cx="61" cy="33" rx="10" ry="13" transform="rotate(6 61 33)"/>
    <ellipse cx="76" cy="48" rx="10" ry="13" transform="rotate(18 76 48)"/>
  </svg>

  <!-- Paw print: small, center-left -->
  <svg class="absolute top-1/2 left-4 -translate-y-1/2 opacity-[0.045] pointer-events-none" style="transform: translateY(-50%) rotate(10deg);"
       width="70" height="70" viewBox="0 0 100 100" fill="white" aria-hidden="true">
    <ellipse cx="50" cy="70" rx="22" ry="18"/>
    <ellipse cx="24" cy="48" rx="10" ry="13" transform="rotate(-18 24 48)"/>
    <ellipse cx="39" cy="33" rx="10" ry="13" transform="rotate(-6 39 33)"/>
    <ellipse cx="61" cy="33" rx="10" ry="13" transform="rotate(6 61 33)"/>
    <ellipse cx="76" cy="48" rx="10" ry="13" transform="rotate(18 76 48)"/>
  </svg>

  <!-- Dotted arc decoration: top center -->
  <svg class="absolute top-0 left-1/2 -translate-x-1/2 opacity-[0.08] pointer-events-none"
       width="600" height="80" viewBox="0 0 600 80" fill="none" aria-hidden="true">
    <path d="M 0 80 Q 300 -20 600 80" stroke="white" stroke-width="1.5" stroke-dasharray="6 10" fill="none"/>
  </svg>

  <!-- Content -->
  <div class="relative max-w-3xl mx-auto px-6 lg:px-10 text-center">

    {eyebrow && (
      <p class="font-body text-sm font-bold tracking-widest uppercase mb-4" style="color: #E8951A;">
        {eyebrow}
      </p>
    )}

    <h2 class="font-heading text-3xl lg:text-4xl text-white font-black leading-tight">
      {heading}
    </h2>

    {subtext && (
      <p class="font-body text-lg text-white/70 mt-4 leading-relaxed max-w-lg mx-auto">
        {subtext}
      </p>
    )}

    <!-- Divider -->
    <div class="flex items-center justify-center gap-4 mt-8 mb-6">
      <div class="h-px w-16 bg-white/20"></div>
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="9" cy="9" r="8" stroke="#E8951A" stroke-width="1.5"/>
        <circle cx="9" cy="9" r="3" fill="#E8951A"/>
      </svg>
      <div class="h-px w-16 bg-white/20"></div>
    </div>

    <!-- Phone number: amber, large -->
    <a
      href={phoneHref}
      class="inline-block font-heading font-black leading-none hover:opacity-85 transition-opacity"
      style="font-size: clamp(2.2rem, 6vw, 3.75rem); color: #E8951A; text-shadow: 0 0 40px rgba(232,149,26,0.35);"
      aria-label={`Call us at ${phone}`}
    >
      {phone}
    </a>

    <!-- CTA button: solid amber -->
    <div class="mt-8">
      <a
        href={ctaHref}
        class="inline-flex items-center gap-2 font-heading font-bold text-base px-8 py-4 rounded-xl text-white transition-all hover:scale-105 hover:shadow-lg"
        style="background: #E8951A; box-shadow: 0 4px 20px rgba(232,149,26,0.4);"
      >
        {ctaLabel}
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
