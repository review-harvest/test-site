---
interface Props {
  businessName?: string;
  phone?: string;
  ctaHref?: string;
}

const {
  businessName = 'Doodie Crew',
  phone = '214-901-0840',
  ctaHref = 'https://client.sweepandgo.com/doodie-crew-pgqy8/register',
} = Astro.props;

const phoneHref = 'tel:+1' + phone.replace(/\D/g, '');

const services = [
  { label: 'Weekly Cleanup', href: '/services/weekly-cleanup', desc: 'Our most popular plan' },
  { label: 'Bi-Weekly Cleanup', href: '/services/biweekly-cleanup', desc: 'Every other week' },
  { label: 'One-Time Cleanup', href: '/services/one-time-cleanup', desc: 'No commitment needed' },
  { label: 'Monthly Deodorizing', href: '/services/monthly-deodorizing', desc: 'Odor treatment' },
];

const areas = [
  { label: 'Prosper', href: '/service-area/prosper' },
  { label: 'Frisco', href: '/service-area/frisco' },
  { label: 'McKinney', href: '/service-area/mckinney' },
  { label: 'Celina', href: '/service-area/celina' },
  { label: 'Little Elm', href: '/service-area/little-elm' },
  { label: 'Aubrey', href: '/service-area/aubrey' },
  { label: 'The Colony', href: '/service-area/the-colony' },
];
---

<style>
  .nav-dropdown { position: relative; }

  /* Bridge: invisible gap-filler so cursor can travel from button → menu */
  .nav-dropdown::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 12px;
  }

  .nav-dropdown .dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: white;
    border: 1px solid #E8E0D4;
    border-radius: 12px;
    box-shadow: 0 8px 30px rgba(26,37,64,0.12);
    min-width: 220px;
    padding: 8px;
    z-index: 100;
    /* Smooth hover-only reveal */
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.18s ease, visibility 0.18s ease, transform 0.18s ease;
    transform: translateX(-50%) translateY(4px);
  }
  .nav-dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  .dropdown-menu::before {
    content: '';
    position: absolute;
    top: -6px;
    left: 50%;
    transform: translateX(-50%);
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-bottom: 6px solid white;
  }
  .dropdown-item {
    display: flex;
    flex-direction: column;
    padding: 10px 12px;
    border-radius: 8px;
    transition: background 0.15s;
    text-decoration: none;
  }
  .dropdown-item:hover { background: #FBF8F3; }
  .dropdown-item .item-label {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.875rem;
    color: #1A2540;
  }
  .dropdown-item .item-desc {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: #6B6560;
    margin-top: 1px;
  }
  .dropdown-divider { height: 1px; background: #E8E0D4; margin: 4px 0; }
  .dropdown-footer-link {
    display: block;
    padding: 8px 12px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: #1B5FBF;
    text-decoration: none;
    border-radius: 6px;
    text-align: center;
  }
  .dropdown-footer-link:hover { background: #FBF8F3; }
  .chevron { transition: transform 0.2s; display: inline-block; margin-left: 3px; }
  .nav-dropdown:hover .chevron { transform: rotate(180deg); }

  /* Client login dropdown — right-aligned */
  .login-dropdown .dropdown-menu {
    left: auto;
    right: 0;
    transform: translateY(4px);
    min-width: 200px;
  }
  .login-dropdown:hover .dropdown-menu {
    transform: translateY(0);
  }
  .login-dropdown .dropdown-menu::before {
    left: auto;
    right: 18px;
    transform: none;
  }

  /* Mobile menu */
  #mobile-menu { display: none; }
  #mobile-menu.open { display: block; }
  .mobile-section-title {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #6B6560;
    padding: 12px 16px 4px;
  }
  .mobile-link {
    display: block;
    padding: 10px 16px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: #1A2540;
    text-decoration: none;
    border-radius: 8px;
    margin: 0 8px;
  }
  .mobile-link:hover { background: #FBF8F3; }
</style>

<header class="sticky top-0 z-50 bg-surface/95 backdrop-blur-sm border-b border-border">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a href="/" class="shrink-0 flex items-center gap-3" aria-label={businessName + ' Home'}>
        <img
          src="/images/logo-dog-head.jpg"
          alt={businessName + ' logo'}
          class="h-16 w-16 rounded-xl shrink-0 object-cover"
        />
        <div class="flex flex-col leading-none">
          <span class="font-heading text-xl font-black" style="color: #1B5FBF;">{businessName}</span>
          <span class="font-body text-[10px] font-semibold tracking-widest uppercase" style="color: #E8951A;">Dog Waste Removal</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-0" aria-label="Main navigation">

        <!-- Services dropdown -->
        <div class="nav-dropdown">
          <button class="flex items-center gap-1 font-body text-[14px] font-medium text-text-soft hover:text-text transition-colors px-2 py-2 rounded-md hover:bg-bg cursor-default">
            Services
            <svg class="chevron w-3.5 h-3.5 text-text-soft" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </button>
          <div class="dropdown-menu">
            {services.map(s => (
              <a href={s.href} class="dropdown-item">
                <span class="item-label">{s.label}</span>
                {s.desc && <span class="item-desc">{s.desc}</span>}
              </a>
            ))}
            <div class="dropdown-divider"></div>
            <a href="/services" class="dropdown-footer-link">View all services →</a>
          </div>
        </div>

        <!-- Service Area dropdown -->
        <div class="nav-dropdown">
          <button class="flex items-center gap-1 font-body text-[14px] font-medium text-text-soft hover:text-text transition-colors px-2 py-2 rounded-md hover:bg-bg cursor-default">
            Service Area
            <svg class="chevron w-3.5 h-3.5 text-text-soft" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </button>
          <div class="dropdown-menu">
            {areas.map(a => (
              <a href={a.href} class="dropdown-item">
                <span class="item-label">{a.label}, TX</span>
              </a>
            ))}
            <div class="dropdown-divider"></div>
            <a href="/service-area" class="dropdown-footer-link">Full service area →</a>
          </div>
        </div>

        <a href="/about" class="font-body text-[14px] font-medium text-text-soft hover:text-text transition-colors px-2 py-2 rounded-md hover:bg-bg">About</a>
        <a href="/reviews" class="font-body text-[14px] font-medium text-text-soft hover:text-text transition-colors px-2 py-2 rounded-md hover:bg-bg">Reviews</a>
        <a href="/faq" class="font-body text-[14px] font-medium text-text-soft hover:text-text transition-colors px-2 py-2 rounded-md hover:bg-bg">FAQ</a>
        <a href="/contact" class="font-body text-[14px] font-medium text-text-soft hover:text-text transition-colors px-2 py-2 rounded-md hover:bg-bg">Contact</a>
      </nav>

      <!-- Right: phone + CTA + hamburger -->
      <div class="flex items-center gap-3 shrink-0">
        <a
          href={phoneHref}
          class="hidden md:flex items-center gap-1.5 font-body text-sm font-semibold text-text hover:text-brand transition-colors"
          aria-label={`Call us at ${phone}`}
        >
          <svg class="w-3.5 h-3.5 text-brand shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          {phone}
        </a>

        <!-- Client Login link -->
        <a
          href="https://client.sweepandgo.com/login/doodie-crew-pgqy8"
          class="hidden md:flex items-center gap-1.5 font-body text-[15px] font-medium text-text-soft hover:text-text transition-colors px-3 py-2 rounded-md hover:bg-bg border border-border"
          target="_blank"
          rel="noopener"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
          Client Login
        </a>

        <a
          href={ctaHref}
          class="hidden sm:inline-flex font-body font-semibold text-sm px-4 py-2.5 rounded-md hover:opacity-90 transition-opacity"
          style="background-color: #E8951A; color: #ffffff;"
        >
          Get a Quote
        </a>

        <!-- Hamburger -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden flex flex-col justify-center items-center w-9 h-9 gap-1.5 rounded-md hover:bg-bg transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="block w-5 h-0.5 bg-text-soft rounded-full transition-all" id="hb-1"></span>
          <span class="block w-5 h-0.5 bg-text-soft rounded-full transition-all" id="hb-2"></span>
          <span class="block w-5 h-0.5 bg-text-soft rounded-full transition-all" id="hb-3"></span>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden border-t border-border bg-surface pb-4">
    <div class="mobile-section-title">Services</div>
    {services.map(s => (
      <a href={s.href} class="mobile-link">{s.label}</a>
    ))}
    <a href="/services" class="mobile-link" style="color: #1B5FBF; font-weight: 600;">All Services →</a>

    <div class="mobile-section-title mt-2">Service Area</div>
    {areas.map(a => (
      <a href={a.href} class="mobile-link">{a.label}, TX</a>
    ))}
    <a href="/service-area" class="mobile-link" style="color: #1B5FBF; font-weight: 600;">Full Coverage Map →</a>

    <div class="mobile-section-title mt-2">More</div>
    <a href="/about" class="mobile-link">About</a>
    <a href="/reviews" class="mobile-link">Reviews</a>
    <a href="/faq" class="mobile-link">FAQ</a>
    <a href="/contact" class="mobile-link">Contact</a>

    <div class="mobile-section-title mt-2">Account</div>
    <a href="https://client.sweepandgo.com/login/doodie-crew-pgqy8" class="mobile-link" target="_blank" rel="noopener">Client Login</a>

    <div class="px-4 pt-4">
      <a
        href={ctaHref}
        class="block w-full text-center font-body font-bold text-sm px-4 py-3 rounded-md"
        style="background-color: #E8951A; color: #ffffff;"
      >
        Get a Free Quote
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hb1 = document.getElementById('hb-1');
  const hb2 = document.getElementById('hb-2');
  const hb3 = document.getElementById('hb-3');
  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(isOpen));
    if (isOpen) {
      hb1!.style.transform = 'translateY(8px) rotate(45deg)';
      hb2!.style.opacity = '0';
      hb3!.style.transform = 'translateY(-8px) rotate(-45deg)';
    } else {
      hb1!.style.transform = '';
      hb2!.style.opacity = '';
      hb3!.style.transform = '';
    }
  });
</script>
