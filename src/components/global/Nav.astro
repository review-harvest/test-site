---
interface Props {
  businessName?: string;
  phone?: string;
  links?: Array<{ label: string; href: string }>;
  ctaHref?: string;
}

const {
  businessName = 'Business Name',
  phone = '(555) 000-0000',
  links = [
    { label: 'Services', href: '/services' },
    { label: 'About', href: '/about' },
    { label: 'Contact', href: '/contact' },
  ],
  ctaHref = '/contact',
} = Astro.props;

const phoneHref = 'tel:+1' + phone.replace(/\D/g, '');
---

<header class="sticky top-0 z-50 bg-surface/95 backdrop-blur-sm border-b border-border">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="font-heading text-xl text-text hover:text-brand transition-colors shrink-0">
        {businessName}
      </a>

      <!-- Nav links (desktop) -->
      <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
        {links.map((link) => (
          <a
            href={link.href}
            class="font-body text-sm font-medium text-text-soft hover:text-text transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right side: phone + CTA -->
      <div class="flex items-center gap-3 shrink-0">
        <a
          href={phoneHref}
          class="hidden md:flex items-center gap-1.5 font-body text-sm font-semibold text-text hover:text-brand transition-colors"
          aria-label={`Call us at ${phone}`}
        >
          <svg class="w-3.5 h-3.5 text-brand shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          {phone}
        </a>

        <a
          href={ctaHref}
          class="bg-brand text-brand-fg font-body font-semibold text-sm px-4 py-2.5 rounded-md hover:opacity-90 transition-opacity"
        >
          Get a Quote
        </a>
      </div>

    </div>
  </div>
</header>
