---
interface Credential {
  label: string;
  value: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  credentials?: Credential[];
}

const {
  eyebrow = 'Licenses & Certifications',
  heading = "You can verify everything we claim.",
  credentials = [
    { label: 'State License', value: '#000000' },
    { label: 'Fully Insured', value: 'General Liability & Workers Comp' },
    { label: 'BBB Accredited', value: 'A+ Rating' },
    { label: 'Google Verified', value: '4.9★ Rating' },
    { label: 'Platform Certified', value: 'Super Service Award' },
    { label: 'In Business Since', value: '2009' },
  ],
} = Astro.props;
---

<section class="bg-neutral-950 py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">

      <!-- Left: text -->
      <div class="lg:col-span-4">
        {eyebrow && (
          <div class="inline-flex items-center gap-2.5 mb-4">
            <span class="block w-5 h-px bg-brand" aria-hidden="true"></span>
            <span class="font-body text-sm font-semibold tracking-widest uppercase text-brand">
              {eyebrow}
            </span>
          </div>
        )}
        <h2 class="font-heading text-2xl lg:text-3xl text-white leading-tight">{heading}</h2>
        <p class="font-body text-sm text-white/50 mt-4 leading-relaxed">
          Our license numbers, insurance certificates, and third-party ratings are all publicly verifiable. We have nothing to hide.
        </p>
      </div>

      <!-- Right: credential grid -->
      <div class="lg:col-span-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-white/10 rounded-lg overflow-hidden">
          {credentials.map((cred) => (
            <div class="bg-neutral-900 px-6 py-5">
              <p class="font-body text-xs font-semibold tracking-widest uppercase text-white/35 mb-1.5">
                {cred.label}
              </p>
              <p class="font-body text-sm font-semibold text-white leading-snug">
                {cred.value}
              </p>
            </div>
          ))}
        </div>
      </div>

    </div>

  </div>
</section>
